        <dc:Bounds x="1940" y="700" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="DataStoreRef_Applications_di" bpmnElement="DataStoreRef_Applications">
        <dc:Bounds x="1220" y="710" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1228" y="767" width="34" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="DataStoreRef_Programs_di" bpmnElement="DataStoreRef_Programs">
        <dc:Bounds x="480" y="735" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="463" y="792" width="85" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="DataStoreRef_Tariffs_di" bpmnElement="DataStoreRef_Tariffs">
        <dc:Bounds x="660" y="735" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="665" y="792" width="40" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Skillbox_FixPaymentSuccess_di" bpmnElement="Skillbox_FixPaymentSuccess">
        <dc:Bounds x="1940" y="540" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Skillbox_CatchPaymentSuccess_di" bpmnElement="Skillbox_CatchPaymentSuccess">
        <dc:Bounds x="1855" y="592" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1835" y="628" width="76" height="27" />
