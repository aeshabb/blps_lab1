<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_Skillbox_Final" targetNamespace="http://example.com/bpmn/skillbox/final" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.13.1">
  <bpmn:message id="Message_RequestPage" name="Запрос страницы программы" />
  <bpmn:message id="Message_ProgramData" name="Данные программы и тарифов" />
  <bpmn:message id="Message_Application" name="Заявка на обучение" />
  <bpmn:message id="Message_PaymentLink" name="Ссылка на оплату" />
  <bpmn:message id="Message_PaymentRequest" name="Платежный запрос" />
  <bpmn:message id="Message_PaymentSuccess" name="Подтверждение оплаты" />
  <bpmn:message id="Message_PaymentFail" name="Отказ оплаты" />
  <bpmn:message id="Message_EnrollRequest" name="Запрос на зачисление" />
  <bpmn:message id="Message_EnrollConfirm" name="Подтверждение зачисления" />
  <bpmn:message id="Message_AccessData" name="Данные доступа" />
  <bpmn:message id="Message_Refusal" name="Уведомление об отказе" />
  <bpmn:dataStore id="DataStore_Programs" name="БД программ" />
  <bpmn:dataStore id="DataStore_Tariffs" name="БД тарифов" />
  <bpmn:dataStore id="DataStore_Applications" name="БД заявок и заказов" />
  <bpmn:dataStore id="DataStore_Payments" name="БД оплат" />
  <bpmn:dataStore id="DataStore_OE_Users" name="БД пользователей Open edX" />
  <bpmn:dataStore id="DataStore_OE_Enrollments" name="БД зачислений Open edX" />
  <bpmn:collaboration id="Collaboration_SkillboxEnrollment">
    <bpmn:participant id="Participant_User" name="Пользователь" processRef="Process_User" />
    <bpmn:participant id="Participant_Skillbox" name="Skillbox" processRef="Process_Skillbox" />
    <bpmn:participant id="Participant_Bank" name="Платежный сервис / Банк" processRef="Process_Bank" />
    <bpmn:participant id="Participant_OpenEdX" name="Open edX" processRef="Process_OpenEdX" />
    <bpmn:messageFlow id="MessageFlow_RequestPage" name="Запрос страницы" sourceRef="UserTask_RequestPage" targetRef="Skillbox_LoadPrograms" />
    <bpmn:messageFlow id="MessageFlow_ProgramData" name="Данные программы и тарифов" sourceRef="Skillbox_SendProgramData" targetRef="UserTask_ReceiveProgramData" />
    <bpmn:messageFlow id="MessageFlow_Application" name="Заявка" sourceRef="UserTask_SendApplication" targetRef="Skillbox_ReceiveApplication" />
    <bpmn:messageFlow id="MessageFlow_PaymentLink" name="Ссылка на оплату" sourceRef="Skillbox_SendPaymentLink" targetRef="UserTask_ReceivePaymentLink" />
    <bpmn:messageFlow id="MessageFlow_PaymentRequest" name="Платежный запрос" sourceRef="UserTask_PayProgram" targetRef="Start_Bank_PaymentRequest" />
    <bpmn:messageFlow id="MessageFlow_PaymentSuccess" name="Статус оплаты: успех" sourceRef="Bank_SendSuccess" targetRef="Skillbox_CatchPaymentSuccess" />
    <bpmn:messageFlow id="MessageFlow_PaymentFail" name="Статус оплаты: отказ" sourceRef="Bank_SendFail" targetRef="Skillbox_CatchPaymentFail" />
    <bpmn:messageFlow id="MessageFlow_EnrollRequest" name="Запрос на зачисление" sourceRef="Skillbox_SendOpenEdXRequest" targetRef="Start_OpenEdX_Request" />
    <bpmn:messageFlow id="MessageFlow_EnrollConfirm" name="Подтверждение зачисления" sourceRef="OpenEdX_SendConfirmation" targetRef="Skillbox_CatchOpenEdXConfirmation" />
    <bpmn:messageFlow id="MessageFlow_AccessData" name="Данные доступа" sourceRef="UserTask_ReceiveAccess" targetRef="Skillbox_SendAccessData" />
    <bpmn:messageFlow id="MessageFlow_Refusal" name="Уведомление об отказе" sourceRef="End_User_Fail" targetRef="Skillbox_SendOpenEdXRequest" />
  </bpmn:collaboration>
  <bpmn:process id="Process_User" isExecutable="false">
    <bpmn:startEvent id="Start_User" name="Интерес к программе" />
    <bpmn:userTask id="UserTask_RequestPage" name="Запросить страницу программы" />
    <bpmn:receiveTask id="UserTask_ReceiveProgramData" name="Получить программу и тарифы" messageRef="Message_ProgramData" />
    <bpmn:userTask id="UserTask_ChooseTariff" name="Выбрать программу и тариф" />
    <bpmn:userTask id="UserTask_FillApplication" name="Заполнить заявку" />
    <bpmn:sendTask id="UserTask_SendApplication" name="Отправить заявку" messageRef="Message_Application" />
    <bpmn:receiveTask id="UserTask_ReceivePaymentLink" name="Получить ссылку на оплату" messageRef="Message_PaymentLink" />
    <bpmn:eventBasedGateway id="UserGateway_WaitResult" name="Ожидать ответ по доступу" />
    <bpmn:receiveTask id="UserTask_ReceiveAccess" name="Получить подтверждение доступа" messageRef="Message_AccessData" />
    <bpmn:receiveTask id="UserTask_ReceiveRefusal" name="Получить отказ от Open edX" messageRef="Message_Refusal" />
    <bpmn:endEvent id="End_User_Success" name="Запись завершена" />
    <bpmn:endEvent id="End_User_Fail" name="Запись не завершена" />
    <bpmn:userTask id="UserTask_PayProgram" name="Оплатить программу" />
    <bpmn:sequenceFlow id="UF1" sourceRef="Start_User" targetRef="UserTask_RequestPage" />
    <bpmn:sequenceFlow id="UF2" sourceRef="UserTask_RequestPage" targetRef="UserTask_ReceiveProgramData" />
    <bpmn:sequenceFlow id="UF3" sourceRef="UserTask_ReceiveProgramData" targetRef="UserTask_ChooseTariff" />
    <bpmn:sequenceFlow id="UF4" sourceRef="UserTask_ChooseTariff" targetRef="UserTask_FillApplication" />
    <bpmn:sequenceFlow id="UF5" sourceRef="UserTask_FillApplication" targetRef="UserTask_SendApplication" />
    <bpmn:sequenceFlow id="UF6" sourceRef="UserTask_SendApplication" targetRef="UserTask_ReceivePaymentLink" />
    <bpmn:sequenceFlow id="UF7" sourceRef="UserTask_ReceivePaymentLink" targetRef="UserTask_PayProgram" />
    <bpmn:sequenceFlow id="UF8" sourceRef="UserTask_PayProgram" targetRef="UserGateway_WaitResult" />
    <bpmn:sequenceFlow id="UF9" sourceRef="UserGateway_WaitResult" targetRef="UserTask_ReceiveAccess" />
    <bpmn:sequenceFlow id="UF10" sourceRef="UserGateway_WaitResult" targetRef="UserTask_ReceiveRefusal" />
    <bpmn:sequenceFlow id="UF11" sourceRef="UserTask_ReceiveAccess" targetRef="End_User_Success" />
    <bpmn:sequenceFlow id="UF12" sourceRef="UserTask_ReceiveRefusal" targetRef="End_User_Fail" />
  </bpmn:process>
  <bpmn:process id="Process_Skillbox" isExecutable="false">
    <bpmn:startEvent id="Start_Skillbox_Request" name="Получен запрос страницы">
      <bpmn:messageEventDefinition messageRef="Message_RequestPage" />
    </bpmn:startEvent>
    <bpmn:serviceTask id="Skillbox_LoadPrograms" name="Загрузить программы из БД" />
    <bpmn:serviceTask id="Skillbox_LoadTariffs" name="Загрузить тарифы из БД" />
    <bpmn:sendTask id="Skillbox_SendProgramData" name="Показать программу и тарифы" messageRef="Message_ProgramData" />
    <bpmn:receiveTask id="Skillbox_ReceiveApplication" name="Получить заявку" messageRef="Message_Application" />
    <bpmn:serviceTask id="Skillbox_ValidateSaveApplication" name="Проверить и сохранить заявку" />
    <bpmn:serviceTask id="Skillbox_GeneratePaymentLink" name="Сформировать ссылку на оплату" />
    <bpmn:sendTask id="Skillbox_SendPaymentLink" name="Отправить ссылку на оплату" messageRef="Message_PaymentLink" />
    <bpmn:eventBasedGateway id="Skillbox_Gateway_WaitPayment" name="Ожидать статус оплаты" />
    <bpmn:intermediateCatchEvent id="Skillbox_CatchPaymentFail" name="Получен отказ оплаты">
      <bpmn:messageEventDefinition messageRef="Message_PaymentFail" />
    </bpmn:intermediateCatchEvent>
    <bpmn:sendTask id="Skillbox_SendOpenEdXRequest" name="Передать данные в Open edX" messageRef="Message_EnrollRequest" />
    <bpmn:intermediateCatchEvent id="Skillbox_CatchOpenEdXConfirmation" name="Получено подтверждение Open edX">
      <bpmn:messageEventDefinition messageRef="Message_EnrollConfirm" />
    </bpmn:intermediateCatchEvent>
    <bpmn:serviceTask id="Skillbox_SaveAccessData" name="Сохранить доступ и зачисление" />
    <bpmn:sendTask id="Skillbox_SendAccessData" name="Отправить данные доступа" messageRef="Message_AccessData" />
    <bpmn:endEvent id="End_Skillbox_Success" name="Пользователь зачислен" />
    <bpmn:serviceTask id="Skillbox_FixPaymentFail" name="Зафиксировать отказ оплаты" />
    <bpmn:dataStoreReference id="DataStoreRef_Applications" name="заявки" dataStoreRef="DataStore_Applications" />
    <bpmn:dataStoreReference id="DataStoreRef_Programs" name="образовательные  программ" dataStoreRef="DataStore_Programs" />
    <bpmn:dataStoreReference id="DataStoreRef_Tariffs" name="тарифы" dataStoreRef="DataStore_Tariffs" />
    <bpmn:serviceTask id="Skillbox_FixPaymentSuccess" name="Зафиксировать оплату в БД" />
    <bpmn:intermediateCatchEvent id="Skillbox_CatchPaymentSuccess" name="Получен успех оплаты">
      <bpmn:messageEventDefinition messageRef="Message_PaymentSuccess" />
    </bpmn:intermediateCatchEvent>
    <bpmn:dataStoreReference id="DataStoreRef_Payments" name="транзакции оплаты" dataStoreRef="DataStore_Payments" />
    <bpmn:sendTask id="Skillbox_SendRefusal" name="Отправить уведомление об отказе" messageRef="Message_Refusal" />
    <bpmn:endEvent id="End_Skillbox_Fail" name="Запись отменена" />
    <bpmn:sequenceFlow id="SF1" sourceRef="Start_Skillbox_Request" targetRef="Skillbox_LoadPrograms" />
    <bpmn:sequenceFlow id="SF2" sourceRef="Skillbox_LoadPrograms" targetRef="Skillbox_LoadTariffs" />
    <bpmn:sequenceFlow id="SF3" sourceRef="Skillbox_LoadTariffs" targetRef="Skillbox_SendProgramData" />
    <bpmn:sequenceFlow id="SF4" sourceRef="Skillbox_SendProgramData" targetRef="Skillbox_ReceiveApplication" />
    <bpmn:sequenceFlow id="SF5" sourceRef="Skillbox_ReceiveApplication" targetRef="Skillbox_ValidateSaveApplication" />
    <bpmn:sequenceFlow id="SF6" sourceRef="Skillbox_ValidateSaveApplication" targetRef="Skillbox_GeneratePaymentLink" />
    <bpmn:sequenceFlow id="SF7" sourceRef="Skillbox_GeneratePaymentLink" targetRef="Skillbox_SendPaymentLink" />
    <bpmn:sequenceFlow id="SF8" sourceRef="Skillbox_SendPaymentLink" targetRef="Skillbox_Gateway_WaitPayment" />
    <bpmn:sequenceFlow id="SF9" sourceRef="Skillbox_Gateway_WaitPayment" targetRef="Skillbox_CatchPaymentSuccess" />
    <bpmn:sequenceFlow id="SF10" sourceRef="Skillbox_Gateway_WaitPayment" targetRef="Skillbox_CatchPaymentFail" />
    <bpmn:sequenceFlow id="SF17" sourceRef="Skillbox_CatchPaymentFail" targetRef="Skillbox_FixPaymentFail" />
    <bpmn:sequenceFlow id="SF12" sourceRef="Skillbox_FixPaymentSuccess" targetRef="Skillbox_SendOpenEdXRequest" />
    <bpmn:sequenceFlow id="SF13" sourceRef="Skillbox_SendOpenEdXRequest" targetRef="Skillbox_CatchOpenEdXConfirmation" />
    <bpmn:sequenceFlow id="SF14" sourceRef="Skillbox_CatchOpenEdXConfirmation" targetRef="Skillbox_SaveAccessData" />
    <bpmn:sequenceFlow id="SF15" sourceRef="Skillbox_SaveAccessData" targetRef="Skillbox_SendAccessData" />
    <bpmn:sequenceFlow id="SF16" sourceRef="Skillbox_SendAccessData" targetRef="End_Skillbox_Success" />
    <bpmn:sequenceFlow id="SF18" sourceRef="Skillbox_FixPaymentFail" targetRef="Skillbox_SendRefusal" />
    <bpmn:sequenceFlow id="SF11" sourceRef="Skillbox_CatchPaymentSuccess" targetRef="Skillbox_FixPaymentSuccess" />
    <bpmn:sequenceFlow id="SF19" sourceRef="Skillbox_SendRefusal" targetRef="End_Skillbox_Fail" />
    <bpmn:association id="Assoc_Programs" sourceRef="Skillbox_LoadPrograms" targetRef="DataStoreRef_Programs" />
    <bpmn:association id="Assoc_Tariffs" sourceRef="Skillbox_LoadTariffs" targetRef="DataStoreRef_Tariffs" />
    <bpmn:association id="Assoc_Applications" sourceRef="Skillbox_ValidateSaveApplication" targetRef="DataStoreRef_Applications" />
    <bpmn:association id="Assoc_PayFail" sourceRef="Skillbox_FixPaymentFail" targetRef="DataStoreRef_Payments" />
    <bpmn:association id="Assoc_PaySuccess" sourceRef="Skillbox_FixPaymentSuccess" targetRef="DataStoreRef_Payments" />
  </bpmn:process>
  <bpmn:process id="Process_Bank" isExecutable="false">
    <bpmn:startEvent id="Start_Bank_PaymentRequest" name="Получен платежный запрос">
      <bpmn:messageEventDefinition messageRef="Message_PaymentRequest" />
    </bpmn:startEvent>
    <bpmn:serviceTask id="Bank_ProcessPayment" name="Обработать платеж" />
    <bpmn:exclusiveGateway id="Bank_Gateway_Success" name="Оплата успешна?" />
    <bpmn:sendTask id="Bank_SendSuccess" name="Отправить подтверждение оплаты" messageRef="Message_PaymentSuccess" />
    <bpmn:sendTask id="Bank_SendFail" name="Отправить отказ оплаты" messageRef="Message_PaymentFail" />
    <bpmn:endEvent id="End_Bank_Success" name="Успех" />
    <bpmn:endEvent id="End_Bank_Fail" name="Отказ" />
    <bpmn:sequenceFlow id="BF1" sourceRef="Start_Bank_PaymentRequest" targetRef="Bank_ProcessPayment" />
    <bpmn:sequenceFlow id="BF2" sourceRef="Bank_ProcessPayment" targetRef="Bank_Gateway_Success" />
    <bpmn:sequenceFlow id="BF3" name="Да" sourceRef="Bank_Gateway_Success" targetRef="Bank_SendSuccess" />
    <bpmn:sequenceFlow id="BF4" name="Нет" sourceRef="Bank_Gateway_Success" targetRef="Bank_SendFail" />
    <bpmn:sequenceFlow id="BF5" sourceRef="Bank_SendSuccess" targetRef="End_Bank_Success" />
    <bpmn:sequenceFlow id="BF6" sourceRef="Bank_SendFail" targetRef="End_Bank_Fail" />
  </bpmn:process>
  <bpmn:process id="Process_OpenEdX" isExecutable="false">
    <bpmn:startEvent id="Start_OpenEdX_Request" name="Получен запрос на зачисление">
      <bpmn:messageEventDefinition messageRef="Message_EnrollRequest" />
    </bpmn:startEvent>
    <bpmn:serviceTask id="OpenEdX_CheckUser" name="Проверить пользователя в Open edX" />
    <bpmn:exclusiveGateway id="OpenEdX_Gateway_UserExists" name="Пользователь существует?" />
    <bpmn:serviceTask id="OpenEdX_CreateAccount" name="Создать аккаунт">
      <bpmn:dataOutputAssociation id="DataOutputAssociation_0ujna9e">
        <bpmn:targetRef>DataStoreRef_OE_Users</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="OpenEdX_Enroll" name="Зачислить на программу">
      <bpmn:dataOutputAssociation id="DataOutputAssociation_0bajukf">
        <bpmn:targetRef>DataStoreRef_OE_Enrollments</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="OpenEdX_OpenAccess" name="Открыть доступ к курсам" />
    <bpmn:sendTask id="OpenEdX_SendConfirmation" name="Отправить подтверждение" messageRef="Message_EnrollConfirm" />
    <bpmn:endEvent id="End_OpenEdX" name="Зачисление завершено" />
    <bpmn:dataStoreReference id="DataStoreRef_OE_Users" name="пользователи Open edX" dataStoreRef="DataStore_OE_Users" />
    <bpmn:dataStoreReference id="DataStoreRef_OE_Enrollments" name="транзакции зачислений Open edX" dataStoreRef="DataStore_OE_Enrollments" />
    <bpmn:sequenceFlow id="OF1" sourceRef="Start_OpenEdX_Request" targetRef="OpenEdX_CheckUser" />
    <bpmn:sequenceFlow id="OF2" sourceRef="OpenEdX_CheckUser" targetRef="OpenEdX_Gateway_UserExists" />
    <bpmn:sequenceFlow id="OF3" name="Да" sourceRef="OpenEdX_Gateway_UserExists" targetRef="OpenEdX_Enroll" />
    <bpmn:sequenceFlow id="OF4" name="Нет" sourceRef="OpenEdX_Gateway_UserExists" targetRef="OpenEdX_CreateAccount" />
    <bpmn:sequenceFlow id="OF5" sourceRef="OpenEdX_CreateAccount" targetRef="OpenEdX_Enroll" />
    <bpmn:sequenceFlow id="OF6" sourceRef="OpenEdX_Enroll" targetRef="OpenEdX_OpenAccess" />
    <bpmn:sequenceFlow id="OF7" sourceRef="OpenEdX_OpenAccess" targetRef="OpenEdX_SendConfirmation" />
    <bpmn:sequenceFlow id="OF8" sourceRef="OpenEdX_SendConfirmation" targetRef="End_OpenEdX" />
    <bpmn:association id="Assoc_OE_Check" sourceRef="OpenEdX_CheckUser" targetRef="DataStoreRef_OE_Users" />
    <bpmn:association id="Assoc_OE_Access" sourceRef="OpenEdX_OpenAccess" targetRef="DataStoreRef_OE_Enrollments" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_SkillboxFinal">
    <bpmndi:BPMNPlane id="BPMNPlane_SkillboxFinal" bpmnElement="Collaboration_SkillboxEnrollment">
      <bpmndi:BPMNShape id="Participant_Skillbox_di" bpmnElement="Participant_Skillbox" isHorizontal="true">
        <dc:Bounds x="280" y="490" width="2620" height="350" />
